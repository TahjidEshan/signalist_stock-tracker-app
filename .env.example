# ---- Core app ----
MONGODB_URI=mongodb://localhost:27017/signalist
NODE_ENV=development

# Better Auth
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# ---- Market data (Finnhub) ----
FINNHUB_API_KEY=your-finnhub-key
NEXT_PUBLIC_FINNHUB_API_KEY=your-finnhub-key

# ---- Email (nodemailer / Gmail) ----
NODEMAILER_EMAIL=you@gmail.com
NODEMAILER_PASSWORD=your-gmail-app-password

# ---- Local AI (Ollama) ----
# Bare-metal Ollama on the Mac mini. In Docker the compose overrides BASE_URL to
# http://host.docker.internal:11434. Model must match `ollama list` exactly.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- Telegram alerts ----
# Create a bot with @BotFather, then get your chat id (see SIGNALS.md).
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# ---- Signal scanner ----
# Cron for the scan (default every 15 min). Use market-hours-only if you like.
SIGNAL_SCAN_CRON=*/15 * * * *
# Subreddits to scan (comma-separated). Posts AND comments are scraped.
REDDIT_SUBREDDITS=wallstreetbets,stocks,options,StockMarket,investing
REDDIT_USER_AGENT=signalist-scanner/1.0 (personal use)

# ---- SEC EDGAR (insider Form 4 + 8-K filings) ----
# SEC REQUIRES a descriptive User-Agent WITH a real contact email.
SEC_USER_AGENT=signalist-scanner (contact: you@example.com)

# ---- Twitter/X (OPTIONAL, off by default — fragile) ----
TWITTER_ENABLED=false
TWITTER_NITTER_INSTANCE=
TWITTER_QUERIES=$SPY,$QQQ,stocks
